generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AutomationStatus {
  ACTIVE
  INACTIVE
}

enum LogStatus {
  SUCCESS
  FAILED
  PENDING
  SKIPPED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  instagramAccount InstagramAccount?
  automationRules  AutomationRule[]
  automationLogs   AutomationLog[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model InstagramAccount {
  id                    String    @id @default(cuid())
  userId                String    @unique
  instagramUserId       String    @unique
  instagramUsername     String
  facebookPageId        String
  facebookPageName      String?
  accessTokenEncrypted  String    @db.Text
  tokenExpiresAt        DateTime?
  profilePictureUrl     String?
  followersCount        Int       @default(0)
  isConnected           Boolean   @default(true)
  webhookVerified       Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts           InstagramPost[]
  automationRules AutomationRule[]

  @@index([userId])
  @@index([instagramUserId])
  @@map("instagram_accounts")
}

model InstagramPost {
  id                 String   @id @default(cuid())
  instagramAccountId String
  instagramMediaId   String   @unique
  mediaType          String
  mediaUrl           String?  @db.Text
  thumbnailUrl       String?  @db.Text
  permalink          String?  @db.Text
  caption            String?  @db.Text
  timestamp          DateTime
  likeCount          Int      @default(0)
  commentsCount      Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  instagramAccount InstagramAccount @relation(fields: [instagramAccountId], references: [id], onDelete: Cascade)
  automationRules  AutomationRule[]

  @@index([instagramAccountId])
  @@index([instagramMediaId])
  @@map("instagram_posts")
}

model AutomationRule {
  id                 String           @id @default(cuid())
  userId             String
  instagramAccountId String
  instagramPostId    String?
  triggerKeyword     String
  replyMessage       String           @db.Text
  status             AutomationStatus @default(ACTIVE)
  matchCount         Int              @default(0)
  dmSentCount        Int              @default(0)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  instagramAccount InstagramAccount  @relation(fields: [instagramAccountId], references: [id], onDelete: Cascade)
  instagramPost    InstagramPost?    @relation(fields: [instagramPostId], references: [id], onDelete: SetNull)
  automationLogs   AutomationLog[]

  @@index([userId])
  @@index([instagramAccountId])
  @@index([instagramPostId])
  @@index([status])
  @@map("automation_rules")
}

model AutomationLog {
  id               String    @id @default(cuid())
  userId           String
  automationRuleId String?
  commentId        String
  commentText      String    @db.Text
  commenterUsername String
  commenterId      String
  matchedKeyword   String?
  postId           String?
  dmSent           Boolean   @default(false)
  dmMessageId      String?
  status           LogStatus @default(PENDING)
  errorMessage     String?   @db.Text
  retryCount       Int       @default(0)
  processedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  automationRule AutomationRule? @relation(fields: [automationRuleId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([automationRuleId])
  @@index([status])
  @@index([commentId])
  @@index([createdAt])
  @@map("automation_logs")
}
